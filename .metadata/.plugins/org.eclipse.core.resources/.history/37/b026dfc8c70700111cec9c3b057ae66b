package enc;

class Product {
	private int pid;
	private String productName;
	private double price;
	private int quantity;
	public Product(int pid, String productName, double price, int quantity) {
		super();
		this.pid = pid;
		this.productName = productName;
		this.price = price;
		this.quantity = quantity;
	}
	public double getPrice() {
		return price;
	}
	public void setPrice(double price) {
		this.price = price;
	}
	public int getQuantity() {
		return quantity;
	}
	public void setQuantity(int quantity) {
		this.quantity = quantity;
	}
	public int getPid() {
		return pid;
	}
	public String getProductName() {
		return productName;
	}
	
}

public class MainEnc {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
           Product p1 =new Product(1,"Mobile",20000,10);
           String result=String.format("Pid=%d, PName=%s, Price=%lf, and Quantity=%d",
           		p1.getPid(),p1.getProductName(),p1.getPrice(),p1.getQuantity());
           System.err.println(result);
	}

}
